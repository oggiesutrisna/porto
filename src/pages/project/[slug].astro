---
import Layout from '../../layouts/Layout.astro';
import { fetchGitHubUser, fetchRepoReadme } from '../../lib/github';
import { getLanguageColor } from '../../types/github';
import { getFeaturedProjects } from '../../config/featured';
import { marked } from 'marked';
import createDOMPurify from 'dompurify';

const GITHUB_USERNAME = 'oggiesutrisna';
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/projects');
}

let user = null;
let repo = null;
let readme = null;
let readmeHtml = '';
let error = null;
let featured = null;

try {
  user = await fetchGitHubUser(GITHUB_USERNAME);
  repo = user.repositories.find((r) => r.name === slug);
  
  if (!repo) {
    return Astro.redirect('/projects');
  }
  
  readme = await fetchRepoReadme(GITHUB_USERNAME, slug);
  
  if (readme) {
    const { JSDOM } = await import('jsdom');
    const window = new JSDOM('').window;
    const DOMPurify = createDOMPurify(window);
    
    const html = await marked.parse(readme);
    readmeHtml = DOMPurify.sanitize(html);
  }
  
  featured = getFeaturedProjects([slug]).find(f => f.repoName === slug);
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load repository';
}

if (!repo) {
  return Astro.redirect('/projects');
}

const formatDate = (dateString: string): string => {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const siteTitle = `${repo.name}${featured ? ` - ${featured.title}` : ''} | Oggie Sutrisna`;
const siteDescription = repo.description || `View ${repo.name} repository on GitHub`;

// BreadcrumbList schema for project page
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://oggiesutrisna.vercel.app',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Projects',
      item: 'https://oggiesutrisna.vercel.app/#projects',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: featured?.title || repo.name,
    },
  ],
};

// SoftwareApplication schema for project page
const softwareApplicationSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: featured?.title || repo.name,
  description: featured?.description || repo.description || `View ${repo.name} repository on GitHub`,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Person',
    name: 'Oggie Sutrisna',
    url: 'https://oggiesutrisna.vercel.app',
    sameAs: ['https://github.com/oggiesutrisna'],
  },
  url: `https://oggiesutrisna.vercel.app/project/${repo.name}`,
  codeRepository: repo.url,
  datePublished: repo.createdAt,
  dateModified: repo.updatedAt,
  keywords: repo.topics.length > 0 ? repo.topics.join(', ') : 'open source, software development',
  programmingLanguage: repo.languages.length > 0
    ? repo.languages.map((l: any) => l.name).join(', ')
    : repo.language || 'JavaScript',
  ...(repo.license && { license: repo.license }),
  ...(repo.homepage && { browserRequirements: 'Web Browser' }),
  ...(repo.stargazersCount > 0 && {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: Math.min(5, 1 + repo.stargazersCount / 10),
      ratingCount: repo.stargazersCount,
      bestRating: '5',
      worstRating: '1',
    },
  }),
};
---

<Layout title={siteTitle} description={siteDescription}>
  <div class="background-effects">
    <div class="gradient-orb orb-1"></div>
    <div class="gradient-orb orb-2"></div>
    <div class="gradient-orb orb-3"></div>
    <div class="grid-overlay"></div>
    <div class="noise-overlay"></div>
  </div>

  <main id="main-content" class="min-h-screen">
    <div class="container mx-auto px-4 py-12 max-w-5xl">
      <a 
        href="/" 
        class="inline-flex items-center gap-2 text-gray-400 hover:text-white mb-8 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Projects
      </a>

      {error ? (
        <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-6 text-center">
          <h2 class="text-xl font-semibold text-red-400 mb-2">Failed to load project</h2>
          <p class="text-gray-400">{error}</p>
        </div>
      ) : (
        <>
          <header class="mb-8">
            <div class="flex items-start justify-between gap-4 mb-4">
              <h1 class="text-3xl md:text-4xl font-display font-bold text-white">
                {featured?.title || repo.name}
              </h1>
              
              <div class="flex items-center gap-2">
                {repo.homepage && (
                  <a
                    href={repo.homepage}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-primary-600 hover:bg-primary-500 text-white rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-primary-400"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                    Live Demo
                  </a>
                )}
                <a
                  href={repo.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 py-2 bg-dark-border hover:bg-gray-700 text-white rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-primary-400"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  GitHub
                </a>
              </div>
            </div>

            {featured?.description && (
              <p class="text-xl text-gray-400 mb-6">{featured.description}</p>
            )}
            
            {repo.description && (
              <p class="text-lg text-gray-400 mb-6">{repo.description}</p>
            )}

            <div class="flex flex-wrap items-center gap-4 mb-6">
              {repo.language && (
                <div class="flex items-center gap-2 px-3 py-1.5 bg-dark-bg-card rounded-lg">
                  <span 
                    class="w-3 h-3 rounded-full" 
                    style={`background-color: ${getLanguageColor(repo.language)}`}
                  ></span>
                  <span class="text-gray-300">{repo.language}</span>
                </div>
              )}

              <div class="flex items-center gap-2 px-3 py-1.5 bg-dark-bg-card rounded-lg text-gray-300">
                <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <span>{repo.stargazersCount} stars</span>
              </div>

              <div class="flex items-center gap-2 px-3 py-1.5 bg-dark-bg-card rounded-lg text-gray-300">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.707 3.293a1 1 0 010 1.414L5.414 7H11a7 7 0 017 7v2a1 1 0 11-2 0v-2a5 5 0 00-5-5H5.414l2.293 2.293a1 1 0 11-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span>{repo.forksCount} forks</span>
              </div>

              {repo.license && (
                <div class="flex items-center gap-2 px-3 py-1.5 bg-dark-bg-card rounded-lg text-gray-300">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                  </svg>
                  <span>{repo.license}</span>
                </div>
              )}
            </div>

            {repo.languages.length > 1 && (
              <div class="mb-6">
                <h3 class="text-sm font-medium text-gray-400 mb-2">Languages</h3>
                <div class="flex flex-wrap gap-2">
                  {repo.languages.map((lang) => (
                    <div class="flex items-center gap-2 px-3 py-1.5 bg-dark-bg-card rounded-lg">
                      <span 
                        class="w-3 h-3 rounded-full" 
                        style={`background-color: ${lang.color}`}
                      ></span>
                      <span class="text-gray-300">{lang.name}</span>
                      <span class="text-gray-500 text-sm">{lang.percentage}%</span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {repo.topics.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {repo.topics.map((topic) => (
                  <span class="px-3 py-1 text-sm bg-primary-500/10 text-primary-400 rounded-full border border-primary-500/20">
                    {topic}
                  </span>
                ))}
              </div>
            )}
          </header>

          <div class="border-t border-dark-border pt-8">
            <h2 class="text-xl font-display font-semibold text-white mb-6">README</h2>
            
            {readmeHtml ? (
              <article 
                class="prose prose-invert prose-primary max-w-none 
                  prose-headings:text-white 
                  prose-p:text-gray-400 
                  prose-a:text-primary-400 
                  prose-a:no-underline hover:prose-a:underline
                  prose-code:text-primary-300 prose-code:bg-primary-500/10 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
                  prose-pre:bg-dark-bg-card prose-pre:border prose-pre:border-dark-border
                  prose-li:text-gray-400
                  prose-img:rounded-xl"
                set:html={readmeHtml}
              />
            ) : (
              <div class="text-center py-12 bg-dark-bg-card rounded-xl border border-dark-border">
                <svg class="w-16 h-16 mx-auto text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <p class="text-gray-500">No README available for this project</p>
              </div>
            )}
          </div>

          <footer class="mt-12 pt-8 border-t border-dark-border">
            <div class="flex flex-wrap gap-4 text-sm text-gray-500">
              <span>Created: {formatDate(repo.createdAt)}</span>
              <span>Last updated: {formatDate(repo.updatedAt)}</span>
              {repo.isArchived && (
                <span class="px-2 py-1 bg-yellow-500/10 text-yellow-500 rounded">Archived</span>
              )}
            </div>
          </footer>
        </>
      )}
    </div>
  </main>
</Layout>

<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
<script is:inline type="application/ld+json" set:html={JSON.stringify(softwareApplicationSchema)}></script>
