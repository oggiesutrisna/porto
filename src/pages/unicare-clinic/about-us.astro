                                            <div class="emergency__icon">
                                                <i class="icon-call3"></i>
                                            </div>
                                            <a href="tel:+6282298298911" class="phone__number">
                                                <i class="icon-phone"></i> <span>+62 822 9829 8911</span>
                                            </a>
                                            <p>Please feel free to contact our friendly reception staff with any general or medical enquiry.</p>
                                            <a href="/unicare-clinic/appointment.html" class="btn btn__secondary btn__link btn__block">
                                                <span>Make Appointment</span> <i class="icon-arrow-right"></i>
                                            </a>
                                        </div>
                                    </li>
                                    <li>
                                        <i class="icon-phone"></i><a href="tel:+6282298298911">24/7 Hotline: +62 822 9829 8911</a>
                                    </li>
                                    <li>
                                        <i class="icon-location"></i><a href="/unicare-clinic/contact-us.html">Locations: Kuta, Ubud, Nusa Dua, Uluwatu</a>
                                    </li>
                                    <li>
                                        <i class="icon-clock"></i><a href="/unicare-clinic/contact-us.html">Open 24/7, Every Day</a>
                                    </li>
                                </ul>
                                <div class="d-flex">
