---
import UnicareLayout from "../../layouts/UnicareLayout.astro";
---

<UnicareLayout title="About Us - Bali Medical Center Unicare Clinic" description="Discover more about us at Unicare Clinic, a trusted Bali medical clinic offering exceptional healthcare services with expert doctors & modern medical facilities">
    <div class="archive-stripe"></div>
    <div class="archive-banner warning" id="archiveBanner">
        <button class="archive-banner-close" onclick="document.getElementById('archiveBanner').style.display='none'">&times;</button>
        <div class="archive-banner-content">
            <div class="archive-banner-icon">🚧</div>
            <div class="archive-banner-text">
                <h3 class="archive-banner-title">⚠️ ARCHIVE TEMPLATE - DISCONTINUED JANUARY 2025</h3>
                <p class="archive-banner-subtitle">
                    This template is <strong>no longer in use</strong>. I quit as Web Developer in January 2025 and new developers took over,
                    changing everything. This site represents my work from <strong>2019 - 2025</strong> as the original Web Developer for Unicare Clinic.
                </p>
            </div>
            <div class="archive-badge">
                <span class="archive-badge-year">2019</span>
                <span class="archive-badge-label">to</span>
                <span class="archive-badge-year">2025</span>
                <span class="archive-badge-label">My Work</span>
            </div>
        </div>
    </div>
    <div class="archive-stripe"></div>

    <div class="wrapper">
        <div class="preloader">
            <div class="loading"><span></span><span></span><span></span><span></span></div>
