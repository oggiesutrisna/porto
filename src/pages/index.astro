---
import Layout from "../layouts/Layout.astro";
import "../styles/hero.css";
import "../styles/stack.css";
import { techStack } from "../data/techStack";

const siteTitle = "Portfolio | Senior Software Engineer";
const siteDescription =
  "Senior Software Engineer with 8+ years of experience building scalable, high-performance applications and leading technical teams.";
---

<Layout title={siteTitle} description={siteDescription}>
  <!-- Background Effects -->
  <div class="background-effects">
    <div class="gradient-orb orb-1"></div>
    <div class="gradient-orb orb-2"></div>
    <div class="gradient-orb orb-3"></div>
    <div class="grid-overlay"></div>
    <div class="noise-overlay"></div>
  </div>

  <!-- Main Content -->
  <main class="hero">
    <div class="hero-content">
      <!-- Badge -->
      <div class="badge animate-fade-in-up">
        <span class="badge-dot"></span>
        <span>Available for work 24/7</span>
      </div>

      <!-- Heading -->
      <h1 class="hero-title animate-fade-in-up delay-100">
        <span class="title-line">Hello, I'm</span>
        <span class="title-name gradient-text">Oggie Sutrisna</span>
      </h1>

      <!-- Subtitle -->
      <p class="hero-subtitle animate-fade-in-up delay-200">
        Senior Software Engineer with <span class="highlight">8+ years</span> of experience<br
        />
        building scalable, high-performance applications
      </p>

      <!-- CTA Buttons -->
      <div class="cta-container animate-fade-in-up delay-300">
        <a
          href="/oggiesutrisna-cv-2026-damascus.pdf"
          download
          class="btn btn-primary btn-lg"
          id="download-btn"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Download PDF
        </a>
        <a
          href="https://wa.link/1uftn5"
          class="btn btn-secondary btn-lg"
          id="hire-btn"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          Hire Me
        </a>
      </div>

      <!-- Social Links (subtle) -->
      <div class="social-links animate-fade-in-up delay-400">
        <a
          href="https://github.com/oggiesutrisna"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="GitHub"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/oggiesutrisna"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="LinkedIn"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
            ></path>
          </svg>
        </a>
        <a
          href="https://twitter.com/oggiesutrisna"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="Twitter"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Floating Elements -->
    <div class="floating-elements">
      <div class="floating-shape shape-1 animate-float"></div>
      <div
        class="floating-shape shape-2 animate-float"
        style="animation-delay: -2s;"
      >
      </div>
      <div
        class="floating-shape shape-3 animate-float"
        style="animation-delay: -4s;"
      >
      </div>
    </div>
  </main>

  <!-- Tech Stack Section -->
  <section class="stack-section" id="tech-stack">
    <!-- Decorative Elements -->
    <div class="stack-decoration stack-decoration-1"></div>
    <div class="stack-decoration stack-decoration-2"></div>

    <div class="stack-container">
      <!-- Section Header -->
      <div class="stack-header">
        <div class="stack-badge">
          <svg
            class="stack-badge-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
            <polyline points="2 17 12 22 22 17"></polyline>
            <polyline points="2 12 12 17 22 12"></polyline>
          </svg>
          <span>Tech Stack</span>
        </div>
        <h2 class="stack-title gradient-text">Technologies I Work With</h2>
        <p class="stack-subtitle">
          A comprehensive toolkit of modern technologies that I use to build
          exceptional digital experiences
        </p>
      </div>

      <!-- Stack Grid -->
      <div class="stack-grid">
        {
          techStack.map((tech, index) => (
            <article
              class="stack-card stack-animate"
              id={`stack-${tech.title.toLowerCase().replace(" ", "-")}`}
            >
              <div class="stack-card-glow" />
              <div class="stack-card-border" />
              <span class="stack-experience">{tech.experience}</span>

              <div class="stack-icon-container">
                {tech.icon === "server" && (
                  <svg
                    class="stack-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="2" y="2" width="20" height="8" rx="2" ry="2" />
                    <rect x="2" y="14" width="20" height="8" rx="2" ry="2" />
                    <line x1="6" y1="6" x2="6.01" y2="6" />
                    <line x1="6" y1="18" x2="6.01" y2="18" />
                  </svg>
                )}
                {tech.icon === "layout" && (
                  <svg
                    class="stack-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                    <line x1="3" y1="9" x2="21" y2="9" />
                    <line x1="9" y1="21" x2="9" y2="9" />
                  </svg>
                )}
                {tech.icon === "database" && (
                  <svg
                    class="stack-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <ellipse cx="12" cy="5" rx="9" ry="3" />
                    <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                    <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
                  </svg>
                )}
                {tech.icon === "cloud" && (
                  <svg
                    class="stack-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z" />
                  </svg>
                )}
                {tech.icon === "architecture" && (
                  <svg
                    class="stack-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="12" cy="5" r="3" />
                    <circle cx="5" cy="19" r="3" />
                    <circle cx="19" cy="19" r="3" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="12" x2="5" y2="16" />
                    <line x1="12" y1="12" x2="19" y2="16" />
                  </svg>
                )}
                {tech.icon === "wrench" && (
                  <svg
                    class="stack-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                  </svg>
                )}
              </div>

              <h3 class="stack-card-title">{tech.title}</h3>
              <p class="stack-card-description">{tech.description}</p>

              <div class="stack-tags">
                {tech.tags.map((tag) => (
                  <span class="stack-tag">{tag}</span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer animate-fade-in delay-500">
    <p>© 2026 Oggie Sutrisna. All rights reserved.</p>
  </footer>
</Layout>

<script>
  // Interactive glow effect for stack cards
  document.addEventListener("DOMContentLoaded", () => {
    const cards = document.querySelectorAll<HTMLElement>(".stack-card");

    cards.forEach((card) => {
      card.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        card.style.setProperty("--mouse-x", `${x}px`);
        card.style.setProperty("--mouse-y", `${y}px`);
      });

      card.addEventListener("mouseleave", () => {
        // Reset to center when mouse leaves
        card.style.setProperty("--mouse-x", "50%");
        card.style.setProperty("--mouse-y", "50%");
      });
    });
  });
</script>
