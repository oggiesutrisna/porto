---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
    title: string;
    description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <script is:inline>
            (function() {
                const theme = localStorage.getItem('theme') || 'dark';
                if (theme === 'light') {
                    document.documentElement.classList.add('light-mode');
                }
            })();
        </script>

        <meta name="description" content={description} />
        <meta
            name="keywords"
            content="software engineer, senior software engineer, hire software engineer, freelance developer, full-stack developer, web developer, backend developer, frontend developer, software developer for hire, experienced software engineer, remote software engineer, contract developer, technical lead, software architect, hire developer, software engineering services, custom software development, application developer, programming expert, coding professional"
        />
        <meta name="author" content="Oggie Sutrisna" />
        <meta
            name="robots"
            content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
        />
        <meta name="googlebot" content="index, follow" />
        <meta name="generator" content={Astro.generator} />

        <link rel="canonical" href={Astro.url} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta
            property="og:image"
            content="https://oggiesutrisna.vercel.app/og-image.png"
        />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta
            property="og:image:alt"
            content="Senior Software Engineer - Available for Hire"
        />
        <meta
            property="og:site_name"
            content="Oggie Sutrisna | Software Engineer"
        />
        <meta property="og:locale" content="en_US" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={Astro.url} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta
            name="twitter:image"
            content="https://oggiesutrisna.vercel.app/og-image.png"
        />
        <meta
            name="twitter:image:alt"
            content="Senior Software Engineer - Available for Hire"
        />
        <meta name="twitter:creator" content="@oggiesutrisna" />
        <meta name="twitter:site" content="@oggiesutrisna" />

        <meta name="theme-color" content="#ff6b4a" />
        <meta name="msapplication-TileColor" content="#ff6b4a" />
        <meta name="format-detection" content="telephone=no" />
        <meta http-equiv="x-ua-compatible" content="ie=edge" />

        <meta name="geo.region" content="ID" />
        <meta name="geo.placename" content="Indonesia" />

        <script is:inline type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "Person",
                "name": "Oggie Sutrisna",
                "alternateName": "oggiesutrisna",
                "url": "https://oggiesutrisna.vercel.app",
                "image": "https://oggiesutrisna.vercel.app/profile.jpg",
                "sameAs": [
                    "https://github.com/oggiesutrisna",
                    "https://linkedin.com/in/oggiesutrisna",
                    "https://twitter.com/oggiesutrisna"
                ],
                "jobTitle": "Senior Software Engineer",
                "worksFor": {
                    "@type": "Organization",
                    "name": "Available for Hire"
                },
                "description": "Senior Software Engineer with 9+ years of experience building scalable, high-performance applications. Specializing in full-stack development, system architecture, and cloud-native applications. Available for freelance and full-time opportunities.",
                "knowsAbout": [
                    "Software Engineering",
                    "Web Development",
                    "Full-Stack Development",
                    "Backend Development",
                    "Frontend Development",
                    "System Architecture",
                    "Cloud Computing",
                    "Database Design",
                    "API Development",
                    "Agile Methodologies",
                    "Quality Assurance",
                    "Automated Testing",
                    "Test-Driven Development",
                    "System Reliability",
                    "React",
                    "Next.js",
                    "TypeScript",
                    "Node.js",
                    "Go",
                    "PostgreSQL",
                    "PHP",
                    "Blade",
                    "Docker",
                    "Enterprise Internal Tools",
                    "E-commerce API Sync",
                    "Healthcare Data Systems"
                ],
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": "Denpasar",
                    "addressRegion": "Bali",
                    "addressCountry": "Indonesia"
                },
                "nationality": "Indonesian"
            }
        </script>

        <script is:inline type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "WebSite",
                "name": "Oggie Sutrisna | Senior Software Engineer",
                "url": "https://oggiesutrisna.vercel.app",
                "description": "Portfolio of a Senior Software Engineer with 9+ years of experience in full-stack development, system architecture, and cloud-native applications. Specializing in React, Next.js, TypeScript, Node.js, Go, and PHP.",
                "potentialAction": {
                    "@type": "SearchAction",
                    "target": {
                        "@type": "EntryPoint",
                        "urlTemplate": "https://github.com/oggiesutrisna?tab=repositories&q={search_term_string}"
                    },
                    "query-input": "required name=search_term_string"
                }
            }
        </script>

        <script is:inline type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "Service",
                "serviceType": "Software Development",
                "provider": {
                    "@type": "Person",
                    "name": "Oggiesutrisna",
                    "url": "https://oggiesutrisna.vercel.app"
                },
                "areaServed": "Worldwide",
                "availableChannel": {
                    "@type": "ServiceChannel",
                    "serviceUrl": "https://oggiesutrisna.vercel.app",
                    "servicePhone": "+628123456789"
                },
                "description": "Professional software engineering services including web development, API development, system architecture, and technical consulting. Hire an experienced senior software engineer.",
                "offers": {
                    "@type": "Offer",
                    "availability": "https://schema.org/InStock",
                    "priceSpecification": {
                        "@type": "PriceSpecification",
                        "priceCurrency": "USD"
                    }
                }
            }
        </script>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap"
            rel="stylesheet"
        />

        <title>{title}</title>
        <script>
            // Initialize theme before body renders to avoid flash
            const stored = localStorage.getItem('theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const isDark = stored ? stored === 'dark' : prefersDark;
            
            if (!isDark) {
              document.documentElement.classList.add('light-mode');
            }
        </script>
    </head>
    <body>
        <a href="#main-content" class="skip-link">Skip to main content</a>
        <header class="sticky top-0 z-50 backdrop-blur-md header-nav">
            <nav class="container mx-auto max-w-7xl px-4 py-4 flex items-center justify-between">
                <a href="/" class="text-xl font-display font-bold text-primary hover:text-primary-light transition-colors">
                    Oggie
                </a>
                <ThemeToggle />
            </nav>
        </header>
        <slot />
    </body>
</html>

<style>
  .header-nav {
    background-color: var(--color-bg-primary);
    border-bottom: 1px solid var(--color-border);
    transition: all var(--transition-base);
  }
</style>
