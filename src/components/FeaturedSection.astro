---
import type { GitHubRepo } from '../types/github';
import { getFeaturedProjects } from '../config/featured';
import { getLanguageColor } from '../types/github';

interface Props {
  repos: GitHubRepo[];
}

const { repos } = Astro.props;

const featured = getFeaturedProjects(repos.map(r => r.name));
const featuredRepos = featured.map(f => {
  const repo = repos.find(r => r.name === f.repoName);
  return { ...f, repo };
}).filter(item => item.repo) as (typeof featured[0] & { repo: GitHubRepo })[];
---

{featuredRepos.length > 0 && (
  <section class="mb-12">
    <h2 class="text-xl font-display font-semibold text-white mb-6 flex items-center gap-2">
      <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
      Featured Projects
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {featuredRepos.map(({ repo, title, description, badge }) => {
        const languageColor = getLanguageColor(repo.language);
        const isWebsite = repo.homepage || repo.topics.includes('website');
        
        return (
          <a
            href={`/project/${repo.name}`}
            class="group block relative bg-gradient-to-br from-dark-bg-card to-dark-bg-secondary border border-dark-border rounded-2xl p-6 hover:border-primary-500/50 transition-all duration-300 hover:shadow-lg hover:shadow-primary-500/10 focus:outline-none focus:ring-2 focus:ring-primary-500"
          >
            {badge && (
              <span class="absolute top-4 right-4 px-2.5 py-1 text-xs font-medium bg-yellow-500/10 text-yellow-500 rounded-full border border-yellow-500/20">
                {badge}
              </span>
            )}
            
            <h3 class="text-lg font-display font-semibold text-white group-hover:text-primary-400 transition-colors mb-2">
              {title}
            </h3>
            
            <p class="text-gray-400 text-sm mb-4">
              {description}
            </p>
            
            <div class="flex items-center gap-4 text-xs text-gray-500">
              {repo.language && (
                <div class="flex items-center gap-1.5">
                  <span 
                    class="w-2.5 h-2.5 rounded-full" 
                    style={`background-color: ${languageColor}`}
                  ></span>
                  <span>{repo.language}</span>
                </div>
              )}
              
              <div class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <span>{repo.stargazersCount}</span>
              </div>
              
              {repo.forksCount > 0 && (
                <div class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.707 3.293a1 1 0 010 1.414L5.414 7H11a7 7 0 017 7v2a1 1 0 11-2 0v-2a5 5 0 00-5-5H5.414l2.293 2.293a1 1 0 11-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span>{repo.forksCount}</span>
                </div>
              )}
            </div>
            
            <div class="mt-4 flex items-center gap-2">
              {repo.homepage && isWebsite && (
                <span class="inline-flex items-center gap-1 px-2 py-1 text-xs text-primary-400 bg-primary-500/10 rounded">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                  Live Demo
                </span>
              )}
              <span class="inline-flex items-center gap-1 px-2 py-1 text-xs text-gray-500 bg-dark-border rounded">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                View Code
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}
