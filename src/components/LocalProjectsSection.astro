---
import { getLocalProjects } from '../config/local-projects';

const projects = getLocalProjects();

const badgeColors: Record<string, string> = {
  red: 'bg-red-500/10 text-red-500 border-red-500/20',
  yellow: 'bg-yellow-500/10 text-yellow-500 border-yellow-500/20',
  green: 'bg-green-500/10 text-green-500 border-green-500/20',
  blue: 'bg-blue-500/10 text-blue-500 border-blue-500/20',
  purple: 'bg-purple-500/10 text-purple-500 border-purple-500/20',
};
---

{projects.length > 0 && (
  <section class="mb-12">
    <h2 class="text-xl font-display font-semibold text-white mb-6 flex items-center gap-2">
      <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
      </svg>
      Local Projects
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => {
        const badgeColorClass = project.badgeColor
          ? badgeColors[project.badgeColor] || badgeColors.blue
          : badgeColors.blue;

        return (
          <a
            href={project.link}
            class="group block relative bg-gradient-to-br from-dark-bg-card to-dark-bg-secondary border border-dark-border rounded-2xl p-6 hover:border-primary-500/50 transition-all duration-300 hover:shadow-lg hover:shadow-primary-500/10 focus:outline-none focus:ring-2 focus:ring-primary-500"
          >
            {project.badge && (
              <span class={`absolute top-4 right-4 px-2.5 py-1 text-xs font-medium rounded-full border ${badgeColorClass}`}>
                {project.badge}
              </span>
            )}

            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-3">
                {project.icon && (
                  <span class="text-3xl">{project.icon}</span>
                )}
                <h3 class="text-lg font-display font-semibold text-white group-hover:text-primary-400 transition-colors">
                  {project.title}
                </h3>
              </div>
            </div>

            <p class="text-gray-400 text-sm mb-4">
              {project.description}
            </p>

            {project.dates && (
              <div class="flex items-center gap-1.5 text-xs text-gray-500 mb-4">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <span>{project.dates}</span>
              </div>
            )}

            <div class="flex flex-wrap gap-2 mb-4">
              {project.technologies.map((tech) => (
                <span class="px-2 py-1 text-xs text-gray-400 bg-dark-border rounded">
                  {tech}
                </span>
              ))}
            </div>

            <div class="flex items-center gap-2">
              <span class="inline-flex items-center gap-1 px-2 py-1 text-xs text-primary-400 bg-primary-500/10 rounded">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
                View Project
              </span>
              {project.githubLink && (
                <span class="inline-flex items-center gap-1 px-2 py-1 text-xs text-gray-500 bg-dark-border rounded">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  GitHub
                </span>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}
