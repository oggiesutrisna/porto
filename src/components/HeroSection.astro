---
import { fetchGitHubUser } from '../lib/github';

const GITHUB_USERNAME = 'oggiesutrisna';

let user = null;

try {
  user = await fetchGitHubUser(GITHUB_USERNAME);
} catch (e) {
  console.error('Failed to fetch user:', e);
}
---

<section class="relative pt-20 pb-32 md:pt-32 md:pb-40 overflow-hidden">
  {/* Background Effects */}
  <div class="absolute inset-0 z-0">
    <div class="gradient-orb orb-1"></div>
    <div class="gradient-orb orb-2"></div>
    <div class="gradient-orb orb-3"></div>
    <div class="grid-overlay"></div>
    <div class="noise-overlay"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 max-w-5xl">
    {/* Profile Section */}
    <div class="mb-10 animate-fade-in-up">
      {user && (
        <div class="inline-flex items-center gap-3 mb-6 px-4 py-2 rounded-full border border-primary-500/30 bg-primary-500/5 backdrop-blur-sm">
          <img 
            src={user.avatarUrl} 
            alt={user.login}
            class="w-10 h-10 rounded-full border-2 border-primary-500/50"
          />
          <span class="text-sm font-medium text-primary-400">Welcome back! 👋</span>
        </div>
      )}
    </div>

    {/* Main Heading */}
    <div class="mb-8 animate-fade-in-up delay-100">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-extrabold leading-tight mb-6">
        <span class="text-white">Building </span>
        <span class="gradient-text">Beautiful</span>
        <br />
        <span class="text-white">Digital </span>
        <span class="gradient-text">Experiences</span>
      </h1>
    </div>

    {/* Subtitle */}
    <div class="mb-10 animate-fade-in-up delay-200">
      <p class="text-lg md:text-xl text-gray-300 leading-relaxed max-w-3xl mb-4">
        {user?.bio || 'Senior Software Engineer with 8+ years building scalable systems and elegant solutions.'}
      </p>
      <p class="text-base md:text-lg text-gray-400 max-w-3xl">
        Specializing in full-stack development, system architecture, and cloud-native applications. Let's create something amazing together.
      </p>
    </div>

    {/* CTA Buttons */}
    <div class="flex flex-wrap gap-4 animate-fade-in-up delay-300 mb-12">
      <a 
        href="#projects" 
        class="inline-flex items-center gap-2 px-8 py-4 bg-primary-600 hover:bg-primary-500 text-white font-semibold rounded-lg transition-all duration-300 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-400"
      >
        <span>Explore My Work</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
      <a 
        href="/i-putu-oggie-sutrisna-ady_20260227_2116.pdf" 
        download 
        class="inline-flex items-center gap-2 px-8 py-4 border-2 border-primary-500/50 hover:border-primary-500 text-primary-400 hover:text-primary-300 font-semibold rounded-lg transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-primary-400"
      >
        <span>Download CV</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19v-7m0 0V5m0 7H5m7 0h7"/>
        </svg>
      </a>
    </div>

    {/* Stats Section */}
    {user && (
      <div class="grid grid-cols-3 md:grid-cols-4 gap-6 md:gap-8 animate-fade-in-up delay-400 pt-8 border-t border-primary-500/20">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-display font-bold text-primary-400 mb-2">
            {user.repositories.length}+
          </div>
          <p class="text-sm md:text-base text-gray-400">Projects</p>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-display font-bold text-primary-400 mb-2">
            8+
          </div>
          <p class="text-sm md:text-base text-gray-400">Years Exp.</p>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-display font-bold text-primary-400 mb-2">
            ∞
          </div>
          <p class="text-sm md:text-base text-gray-400">Passion</p>
        </div>
        <div class="hidden md:block text-center">
          <div class="text-3xl md:text-4xl font-display font-bold text-primary-400 mb-2">
            100%
          </div>
          <p class="text-sm md:text-base text-gray-400">Committed</p>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  /* Hero-specific styles */
  section {
    position: relative;
  }

  .gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    mix-blend-mode: screen;
  }

  .orb-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.3), transparent);
    top: -100px;
    right: -200px;
    animation: float 15s ease-in-out infinite;
  }

  .orb-2 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.2), transparent);
    bottom: 100px;
    left: -150px;
    animation: float 20s ease-in-out infinite 2s;
  }

  .orb-3 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(236, 72, 153, 0.15), transparent);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: float 18s ease-in-out infinite 4s;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(139, 92, 246, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(139, 92, 246, 0.05) 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.3;
  }

  .noise-overlay {
    position: absolute;
    inset: 0;
    background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="200" height="200"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" result="noise"/></filter><rect width="100%" height="100%" fill="white" filter="url(%23noise)"/></svg>');
    opacity: 0.03;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) translateX(0);
    }
    50% {
      transform: translateY(-30px) translateX(10px);
    }
  }
</style>
