---
import { fetchGitHubUser } from '../lib/github';

const GITHUB_USERNAME = 'oggiesutrisna';

let user = null;

try {
  user = await fetchGitHubUser(GITHUB_USERNAME);
} catch (e) {
  console.error('Failed to fetch user:', e);
}
---

<section class="relative pt-20 pb-32 md:pt-32 md:pb-40 overflow-hidden">
  {/* Background Effects */}
  <div class="absolute inset-0 z-0">
    {/* Orb 1 */}
    <div class="absolute w-[400px] h-[400px] rounded-full blur-[80px] opacity-60 mix-blend-screen animate-float-slow top-[-100px] right-[-200px]" style="background: radial-gradient(circle, rgba(139, 92, 246, 0.3), transparent);"></div>
    {/* Orb 2 */}
    <div class="absolute w-[350px] h-[350px] rounded-full blur-[80px] opacity-60 mix-blend-screen animate-float-slower bottom-[100px] left-[-150px]" style="background: radial-gradient(circle, rgba(168, 85, 247, 0.2), transparent);"></div>
    {/* Orb 3 */}
    <div class="absolute w-[300px] h-[300px] rounded-full blur-[80px] opacity-60 mix-blend-screen animate-float-medium top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" style="background: radial-gradient(circle, rgba(236, 72, 153, 0.15), transparent);"></div>
    {/* Grid Overlay */}
    <div class="absolute inset-0 opacity-30" style="background-image: linear-gradient(rgba(139, 92, 246, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(139, 92, 246, 0.05) 1px, transparent 1px); background-size: 50px 50px;"></div>
    {/* Noise Overlay */}
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,<svg xmlns=&quot;http://www.w3.org/2000/svg&quot; width=&quot;200&quot; height=&quot;200&quot;><filter id=&quot;noise&quot;><feTurbulence type=&quot;fractalNoise&quot; baseFrequency=&quot;0.9&quot; numOctaves=&quot;4&quot; result=&quot;noise&quot;/></filter><rect width=&quot;100%&quot; height=&quot;100%&quot; fill=&quot;white&quot; filter=&quot;url(%23noise)&quot;/></svg>');"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 max-w-5xl">
    {/* Profile Section */}
    <div class="mb-10 animate-fade-in-up">
      {user && (
        <div class="inline-flex items-center gap-3 mb-6 px-4 py-2 rounded-full border border-primary-500/30 bg-primary-500/5 backdrop-blur-sm">
          <img
            src={user.avatarUrl}
            alt={`Profile avatar for ${user.login}`}
            width="40"
            height="40"
            loading="lazy"
            class="w-10 h-10 rounded-full border-2 border-primary-500/50"
          />
          <span class="text-sm font-medium text-primary-400">Welcome back! 👋</span>
        </div>
      )}
    </div>

    {/* Main Heading */}
    <div class="mb-8 animate-fade-in-up delay-100">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-extrabold leading-tight mb-6">
        <span class="text-white">Building </span>
        <span class="gradient-text">Beautiful</span>
        <br />
        <span class="text-white">Digital </span>
        <span class="gradient-text">Experiences</span>
      </h1>
    </div>

    {/* Subtitle */}
    <div class="mb-10 animate-fade-in-up delay-200">
      <p class="text-lg md:text-xl text-gray-300 leading-relaxed max-w-3xl mb-4">
        {user?.bio || 'Senior Software Engineer with 9+ years building scalable systems and elegant solutions.'}
      </p>
      <p class="text-base md:text-lg text-gray-400 max-w-3xl">
        Specializing in full-stack development, system architecture, and cloud-native applications. Let's create something amazing together.
      </p>
    </div>

    {/* CTA Buttons */}
    <div class="flex flex-wrap gap-4 animate-fade-in-up delay-300 mb-12">
      <a 
        href="#projects" 
        class="inline-flex items-center gap-2 px-8 py-4 bg-primary-600 hover:bg-primary-500 text-white font-semibold rounded-lg transition-all duration-300 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-400"
      >
        <span>Explore My Work</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
      <a 
        href="/i-putu-oggie-sutrisna-ady_20260227_2116.pdf" 
        download 
        class="inline-flex items-center gap-2 px-8 py-4 border-2 border-primary-500/50 hover:border-primary-500 text-primary-400 hover:text-primary-300 font-semibold rounded-lg transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-primary-400"
      >
        <span>Download CV</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19v-7m0 0V5m0 7H5m7 0h7"/>
        </svg>
      </a>
    </div>

    {/* Stats Section */}
    {user && (
      <section class="grid grid-cols-3 md:grid-cols-4 gap-6 md:gap-8 animate-fade-in-up delay-400 pt-8 border-t border-primary-500/20" aria-labelledby="stats-heading">
        <h2 id="stats-heading" class="sr-only">Statistics and Experience</h2>
        <dl class="text-center">
          <dt class="text-3xl md:text-4xl font-display font-bold text-primary-400 mb-2">
            {user.repositories.length}+
          </dt>
          <dd class="text-sm md:text-base text-gray-400">Projects</dd>
        </dl>
        <dl class="text-center">
          <dt class="text-3xl md:text-4xl font-display font-bold text-primary-400 mb-2">
            9+
          </dt>
          <dd class="text-sm md:text-base text-gray-400">Years Exp.</dd>
        </dl>
        <dl class="text-center">
          <dt class="text-3xl md:text-4xl font-display font-bold text-primary-400 mb-2">
            ∞
          </dt>
          <dd class="text-sm md:text-base text-gray-400">Passion</dd>
        </dl>
        <dl class="hidden md:block text-center">
          <dt class="text-3xl md:text-4xl font-display font-bold text-primary-400 mb-2">
            100%
          </dt>
          <dd class="text-sm md:text-base text-gray-400">Committed</dd>
        </dl>
      </section>
    )}
  </div>
</section>


